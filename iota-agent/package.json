{
  "name": "@iota/agent",
  "version": "0.1.0",
  "type": "module",
  "description": "HTTP microservice for iota Agent Engine",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -b --force",
    "dev": "tsx watch src/index.ts",
    "start": "bun dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.{ts,json,md}\""
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.0.1",
    "@iota/engine": "file:../iota-engine",
    "fastify": "^5.2.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}