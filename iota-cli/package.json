{
  "name": "@iota/cli",
  "version": "0.1.0",
  "description": "Iota CLI - Command-line interface for Iota Agent Engine",
  "type": "module",
  "bin": {
    "iota": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.{ts,json,md}\""
  },
  "dependencies": {
    "@iota/engine": "file:../iota-engine",
    "commander": "^12.0.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
