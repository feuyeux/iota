# Iota production environment configuration
IOTA_MODE=production
IOTA_HOME=~/.iota

# Unified LLM Configuration
IOTA_BASE_URL=https://api.openai.com/v1
IOTA_MODEL=claude-opus-4.6
IOTA_AUTH_TOKEN=sk-your-api-key-here

# Redis Configuration
REDIS_SENTINEL_HOST=localhost
REDIS_SENTINEL_PORT=26379
REDIS_STREAM_PREFIX=iota:events

# Milvus Configuration
MILVUS_ADDRESS=localhost:19530

# MinIO Configuration
MINIO_ENDPOINT=localhost:9002
MINIO_BUCKET=iota-snapshots
MINIO_ACCESS_KEY=iota
MINIO_SECRET_KEY=iotasecret

# Optional: Embedding provider
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
