{
  "name": "@iota/engine",
  "version": "0.1.0",
  "description": "Iota Agent Engine - Core runtime library",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.{ts,json,md}\""
  },
  "dependencies": {
    "cross-spawn": "^7.0.6",
    "ignore": "^5.3.0",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.0",
    "minio": "^8.0.7",
    "which": "^6.0.1"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/minio": "^7.1.0",
    "@types/node": "^20.11.0",
    "@types/which": "^3.0.4",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  }
}
